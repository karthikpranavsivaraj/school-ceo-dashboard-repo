{
  "name": "institutional-intelligence-platform",
  "version": "1.0.0",
  "private": true,
  "description": "Production-grade microservices for institutional intelligence.",
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "npm test --workspaces --if-present",
    "dev": "npm run dev --workspaces --if-present",
    "clean": "rimraf node_modules packages/*/node_modules"
  },
  "workspaces": [
    "services/*",
    "shared/*"
  ],
  "devDependencies": {
    "typescript": "^5.0.0",
    "rimraf": "^5.0.0",
    "ts-node": "^10.9.1",
    "@types/node": "^20.0.0"
  }
}
